datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                    String   @unique
  name                    String
  description             String
  price                   Int
  original_price          Int?
  precio_venta_punto      Float?   // Nuevo campo opcional
  images                  String[] @default([])
  category_slug           String
  stock                   Int      @default(0)
  rating                  Decimal? @default(0) @db.Decimal
  review_count            Int?     @default(0)
  active                  Boolean? @default(true)
  created_at              DateTime? @default(now()) @db.Timestamptz
  faq                     Json?    @default("[]")
  options                 Json?    @default("[]")
  specifications          Json?    @default("[]")
  features                Json?    @default("[]")
  rich_content            Json?    @default("[]")
  featured                Boolean? @default(false)
  brand_color             String?  @default("#1B2B5E")
  video_url               String?
  landing_config          Json?    @default("{}")
  rich_content_video_url  String?
  product_type            String   @default("landing")
  alegra_item_id          Int?
  alegra_reference        String?

  @@map("products")
}
